{
    "$schema": "https://opencode.ai/config.json",
    "theme": "tokyonight",
    "keybinds": {
        "messages_half_page_down": "alt+d",
        "messages_half_page_up": "alt+u",
        "input_clear": "ctrl+u",
        "messages_last": "ctrl+alt+g",
        "input_newline": "ctrl+enter",
        "session_interrupt": "ctrl+c",
        "app_exit": "<leader>q"
    },
    "lsp": {
        "clangd": {
            "command": [
                "clangd",
                "--background-index",
                "--header-insertion=never",
                "--clang-tidy"
            ],
            "extensions": [
                ".c",
                ".cpp",
                ".h",
                ".hpp",
                ".cc",
                ".hh"
            ]
        },
        "rust-analyzer": {
            "command": [
                "rust-analyzer"
            ],
            "extensions": [
                ".rs"
            ]
        },
        "basedpyright": {
            "command": [
                "basedpyright"
            ],
            "extensions": [
                ".py"
            ]
        },
    },
    "provider": {
        "llama-server": {
            "npm": "@ai-sdk/openai-compatible",
            "name": "LLaMA Server",
            "options": {
                "baseURL": "http://100.64.0.3:11404/v1",
            },
            "models": {
                "qwen3.6-27b:q4_k_xl": {
                    "name": "Qwen 3.6 27B Q4_K_M",
                    "limit": {
                        "context": 256000,
                        "output": 65536
                    }
                },
                "qwen3.6-27b:q8_0": {
                    "name": "Qwen 3.6 27B Q8_0",
                    "limit": {
                        "context": 256000,
                        "output": 65536
                    }
                },
                "qwen3.6-35b-a3b-it:q4_k_xl": {
                    "name": "Qwen 3.6 35B Q4_K_XL",
                    "limit": {
                        "context": 256000,
                        "output": 65536
                    }
                },
                "qwen3.6-35b-a3b-it:q8_k_xl": {
                    "name": "Qwen 3.6 35B Q8_K_XL",
                    "limit": {
                        "context": 256000,
                        "output": 65536
                    }
                }
            }
        }
    },
    "layout": "stretch",
    "agent": {
        "explore": {
            "mode": "subagent",
            "model": "llama-server/qwen3.6-35b-a3b-it:q8_k_xl",
            "description": "Exploratory agent for researching and investigating topics. Use for understanding combined with filtering/synthesizing information to prevent exploding your own context. Perform simple file reads yourself. Only use when actually *synthesizing* information. Don't use it to read files to you; do it yourself."
        },
        "code": {
            "mode": "subagent",
            "model": "llama-server/qwen3.6-35b-a3b-it:q8_k_xl",
            "description": "Agent specialized for code generation. Use for mid-size to larger, but self-contained, code generation/editing tasks to prevent exploding your own context. Perform small edits yourself."
        }
    }
}
